# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_REVIEW_CHAT_ID=
ADMIN_USER_IDS=123456789,987654321

# Posting mode
AUTO_PUBLISH=false
CHECK_INTERVAL_SECONDS=300
MAX_ITEMS_PER_RUN=5
POST_COOLDOWN_MINUTES=10

# Editorial voice
CHANNEL_NAME=где-то в зоне крыла
VOICE_INTENSITY=3
ALLOW_PROFANITY=false
CHANNEL_VOICE=Живой русскоязычный F1/NASCAR-канал: иронично, саркастично, смешно, с ощущением лайв-реакции, но без травли, выдуманных фактов и занудства.

# News feeds. Replace freely; comma-separated RSS/Atom URLs.
NEWS_FEEDS=https://racer.com/category/f1/feed/,https://racer.com/category/nascar/feed/,https://www.motorsport.com/rss/f1/news/

# Optional OpenAI generation. If empty, the bot uses deterministic templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=45

# Local state
DATABASE_PATH=data/wingzone.sqlite3
LOG_LEVEL=INFO
